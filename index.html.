<script>
  // === BDG BACKEND CONFIG — paste your anon key once below ===
  const BDG_URL = 'https://bdywkygsvriaibjddcey.supabase.co';
  const BDG_ANON_KEY = 'PASTE_BDG_ANON_KEY_HERE';
  const SOURCE = 'dealdrive-hub';

  // Reveal
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('shown');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  reveals.forEach((el, i) => {
    if (!el.style.getPropertyValue('--i')) el.style.setProperty('--i', i % 6);
    observer.observe(el);
  });

  // Selection logic
  const cards = document.querySelectorAll('.product-card[data-product]');
  const serviceInput = document.getElementById('service-interest');
  const submitBtn = document.getElementById('submit-btn');
  const hint = document.getElementById('selection-hint');

  cards.forEach((card) => {
    card.addEventListener('click', () => {
      cards.forEach((c) => {
        c.classList.remove('selected');
        c.querySelector('.check').classList.add('hidden');
        c.querySelector('.plus').classList.remove('hidden');
      });
      card.classList.add('selected');
      card.querySelector('.check').classList.remove('hidden');
      card.querySelector('.plus').classList.add('hidden');

      const product = card.dataset.product;
      serviceInput.value = product;
      submitBtn.disabled = false;

      const labels = {
        'DealDrive': 'DealDrive selected · mobile mileage + on-the-go pipeline',
        'DealDesk': 'DealDesk selected · web pipeline + full CRM',
        'Both': 'Bundle selected · DealDrive + DealDesk together'
      };
      hint.textContent = labels[product];
      hint.classList.add('text-emerald-deep', 'font-medium');
      hint.classList.remove('text-slate');

      document.getElementById('waitlist').scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  });

  // Submit
  document.getElementById('waitlist-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const statusEl = document.getElementById('form-status');
    const formData = new FormData(form);
    const product = formData.get('service_interest');
    if (!product) return;

    statusEl.textContent = 'Submitting…';
    statusEl.className = 'text-sm px-4 py-3 rounded-lg form-success';
    statusEl.classList.remove('hidden');

    try {
      const res = await fetch(`${BDG_URL}/rest/v1/bdg_intakes`, {
        method: 'POST',
        headers: {
          'apikey': BDG_ANON_KEY,
          'Authorization': `Bearer ${BDG_ANON_KEY}`,
          'Content-Type': 'application/json',
          'Prefer': 'return=minimal'
        },
        body: JSON.stringify({
          email: formData.get('email'),
          name: formData.get('name') || null,
          company: formData.get('company') || null,
          service_interest: product,
          source: SOURCE,
          status: 'waitlist',
          message: `Hub picker selected: ${product}`
        })
      });
      if (res.ok || res.status === 201) {
        form.reset();
        statusEl.innerHTML = `✓ You're on the <strong>${product}</strong> waitlist. We'll be in touch.`;
        statusEl.className = 'text-sm px-4 py-3 rounded-lg form-success';
        submitBtn.disabled = true;
        cards.forEach((c) => {
          c.classList.remove('selected');
          c.querySelector('.check').classList.add('hidden');
          c.querySelector('.plus').classList.remove('hidden');
        });
      } else {
        throw new Error(`HTTP ${res.status}`);
      }
    } catch (err) {
      statusEl.textContent = 'Something went wrong. Email hello@businessdatagurus.com instead.';
      statusEl.className = 'text-sm px-4 py-3 rounded-lg form-error';
      console.error(err);
    }
  });
</script>

